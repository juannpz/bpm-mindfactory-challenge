# PostgreSQL
POSTGRES_USER=bpm
POSTGRES_PASSWORD=bpm
POSTGRES_DB=bpm_db

# Backend
DATABASE_URL=postgresql://bpm:bpm@localhost:5432/bpm_db
JWT_SECRET_EXTERNAL=super-secret-external-jwt-key
JWT_SECRET_INTERNAL=super-secret-internal-jwt-key
JWT_EXPIRATION=24h
MOCK_AUTH=true
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
API_PORT=3001
FRONTEND_URL=http://localhost:3000
UPLOAD_DIR=/app/uploads

# SMTP (opcional — para magic link real. Sin configurar, loguea en consola)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@bpm.local

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_MOCK_AUTH=true
NEXT_PUBLIC_AZURE_CLIENT_ID=
NEXT_PUBLIC_AZURE_TENANT_ID=
